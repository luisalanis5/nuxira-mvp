[debug] [2026-03-11T02:51:24.343Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/nexia-mvp/rulesets {"name":"projects/nexia-mvp/rulesets/09d783e7-d6bd-466b-be35-ac1281b3bafe","source":{"files":[{"content":"rules_version = '2';\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    \r\n    // Helper: ¿Es el dueño del documento?\r\n    function isOwner(userId) {\r\n      return request.auth != null && request.auth.uid == userId;\r\n    }\r\n\r\n    // Helper: ¿Es Administrador?\r\n    function isAdmin() {\r\n      return request.auth != null && \r\n        exists(/databases/$(database)/documents/creators/$(request.auth.uid)) &&\r\n        get(/databases/$(database)/documents/creators/$(request.auth.uid)).data.role == 'admin';\r\n    }\r\n\r\n    // --- COLECCTION: CREATORS ---\r\n    match /creators/{uid} {\r\n      allow read: if true; \r\n      allow create: if isOwner(uid);\r\n      allow update: if isOwner(uid) && \r\n        (\r\n          !request.resource.data.diff(resource.data).affectedKeys()\r\n            .hasAny(['isPremium', 'isVerified', 'stripeAccountId', 'stripeSetupComplete', 'role', 'balance'])\r\n          || isAdmin()\r\n        );\r\n      \r\n      allow delete: if isAdmin();\r\n\r\n      // --- SUBCOLLECTION: NOTIFICATIONS ---\r\n      match /notifications/{notifId} {\r\n        allow read, update: if isOwner(uid);\r\n        allow create, delete: if isAdmin() || isOwner(uid); \r\n      }\r\n\r\n      // --- SUBCOLLECTION: UNLOCKED_MODULES ---\r\n      match /unlocked_modules/{sessionId} {\r\n        allow read: if isOwner(uid);\r\n        allow write: if false; \r\n      }\r\n\r\n      // --- SUBCOLLECTION: FEED_POSTS ---\r\n      match /feed_posts/{postId} {\r\n        allow read: if true;\r\n        allow create, update, delete: if isOwner(uid);\r\n      }\r\n\r\n      // --- SUBCOLLECTION: MODULOS (Interacción Live / Polls) ---\r\n      match /modules/{moduleId} {\r\n        allow read: if true;\r\n        allow write: if isOwner(uid);\r\n      }\r\n\r\n      // --- SUBCOLLECTION: ANALYTICS ---\r\n      match /analytics_events/{eventId} {\r\n        allow read: if isOwner(uid);\r\n        allow create: if true; // Permitir que cualquier visitante registre un evento (clic)\r\n        allow update, delete: if false;\r\n      }\r\n    }\r\n\r\n    // --- COLECCTION: VERIFICATION REQUESTS ---\r\n    match /verification_requests/{uid} {\r\n      allow read: if isOwner(uid) || isAdmin();\r\n      allow create: if isOwner(uid);\r\n      allow update, delete: if isAdmin();\r\n    }\r\n\r\n    // --- COLECCTION: QUESTIONS (Q&A) ---\r\n    match /questions/{qId} {\r\n      allow create: if true;\r\n      allow read: if resource.data.isPublic == true || isOwner(resource.data.receiverId);\r\n      allow update: if isOwner(resource.data.receiverId);\r\n      allow delete: if isOwner(resource.data.receiverId) || isAdmin();\r\n    }\r\n\r\n    // --- COLECCTION: PLATFORM ADS ---\r\n    match /platform_ads/{adId} {\r\n      allow read: if true;\r\n      allow update: if true; // Permitir incremento de clicks desde el cliente (opcional, ahora se hace vía API)\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    // --- COLECCTION: FEEDBACK & BUGS ---\r\n    match /feedback/{feedbackId} {\r\n      allow create: if request.auth != null;\r\n      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());\r\n      allow delete: if isAdmin();\r\n      allow update: if false;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-03-11T02:51:25.802559Z","metadata":{"services":["cloud.firestore"]}}
