rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: ¿Es el dueño del documento?
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper: ¿Es Administrador?
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/creators/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/creators/$(request.auth.uid)).data.role == 'admin';
    }

    // --- COLECCTION: CREATORS ---
    match /creators/{uid} {
      allow read: if true; 
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) && 
        (
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isPremium', 'isVerified', 'stripeAccountId', 'stripeSetupComplete', 'role', 'balance'])
          || isAdmin()
        );
      
      allow delete: if isAdmin();

      // --- SUBCOLLECTION: NOTIFICATIONS ---
      match /notifications/{notifId} {
        allow read, update: if isOwner(uid);
        allow create, delete: if isAdmin() || isOwner(uid); 
      }

      // --- SUBCOLLECTION: UNLOCKED_MODULES ---
      match /unlocked_modules/{sessionId} {
        allow read: if isOwner(uid);
        allow write: if false; 
      }

      // --- SUBCOLLECTION: FEED_POSTS ---
      match /feed_posts/{postId} {
        allow read: if true;
        allow create, update, delete: if isOwner(uid);
      }

      // --- SUBCOLLECTION: MODULOS (Interacción Live / Polls) ---
      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isOwner(uid);
      }

      // --- SUBCOLLECTION: ANALYTICS ---
      match /analytics_events/{eventId} {
        allow read: if isOwner(uid);
        allow create: if true; // Permitir que cualquier visitante registre un evento (clic)
        allow update, delete: if false;
      }
    }

    // --- COLECCTION: VERIFICATION REQUESTS ---
    match /verification_requests/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update, delete: if isAdmin();
    }

    // --- COLECCTION: QUESTIONS (Q&A) ---
    match /questions/{qId} {
      allow create: if true;
      allow read: if resource.data.isPublic == true || isOwner(resource.data.receiverId);
      allow update: if isOwner(resource.data.receiverId);
      allow delete: if isOwner(resource.data.receiverId) || isAdmin();
    }

    // --- COLECCTION: PLATFORM ADS ---
    match /platform_ads/{adId} {
      allow read: if true;
      allow update: if true; // Permitir incremento de clicks desde el cliente (opcional, ahora se hace vía API)
      allow write: if isAdmin();
    }

    // --- COLECCTION: FEEDBACK & BUGS ---
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
      allow update: if false;
    }
  }
}
